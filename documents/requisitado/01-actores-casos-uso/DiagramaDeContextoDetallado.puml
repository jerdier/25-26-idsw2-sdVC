@startuml
title Diagrama de Contexto (Dashboard Detallado)
left to right direction
skinparam style strictuml
skinparam linetype polyline

<style>
legend {
  BackGroundColor #f0f0f0
}
</style>

legend top
    **DASHBOARD DE CONTEXTO** - <i>Casos de uso</i>
    ====
    |<#gray>     | No detallado aún o retorno |<#green>     | Detallado (Con enlace al .puml) |
end legend

state "SESION_CERRADA" as NoAuth
state "SISTEMA_DISPONIBLE" as Menu

state "ALUMNOS_ABIERTO" as ListAlumnos
state "ALUMNO_DETALLE_ABIERTO" as EditAlumno

state "MATRICULAS_ABIERTO" as ListMatriculas
state "MATRICULA_DETALLE_ABIERTA" as EditMatricula

state "ASISTENCIAS_ABIERTO" as ListAsistencias
state "SESION_CLASE_ABIERTA" as EditSesion

state "DISPENSAS_ABIERTO" as ListDispensas
state "SOLICITUD_DISPENSA_ABIERTA" as EditDispensa

state "USUARIOS_ABIERTO" as ListUsuarios
state "USUARIO_DETALLE_ABIERTO" as EditUsuario

[*] --> NoAuth

' --- CONTROL DE ACCESO ---
NoAuth -[#gray,thickness=2]-> Menu : iniciarSesion()
Menu -[#gray,thickness=2]-> NoAuth : cerrarSesion()
Menu -[#gray,thickness=2]-> NoAuth : sesionInactiva()

