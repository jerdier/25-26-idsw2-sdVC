@startuml
skinparam nodesep 60
skinparam ranksep 60
skinparam linetype polyline
skinparam NoteBackgroundColor lightyellow
skinparam NoteBorderColor gray
skinparam StateBackgroundColor #F5F5F5
skinparam StateBorderColor gray

state "editarUsuario()" as editarUsuario {
   
    ' Estados anónimos vacíos para simular los pasos
    state " " as Paso1
    state " " as Paso2
   
    [*] -[#green]-> Paso1
    note on link
      <b>Administrador</b> solicita editar usuario
    end note
   
    Paso1 -[#green]-> Paso2
    note on link
      <b>Sistema</b> solicita ingresar datos a modificar
      • Nombres Completos y Apellidos Completos
      • Correo Electrónico
      • Rol en el Sistema y Estado
    end note
   
    Paso2 -[#green]-> [*]
    note on link
      <b>Administrador</b> proporciona datos actualizados
      <b>Sistema</b> permite editar usuario
      • Permite solicitar guardar cambios
      • Permite solicitar cerrar usuario
    end note
}


state "USUARIOS_ABIERTO" as USUARIOS_ABIERTO

editarUsuario -[#green]---> USUARIOS_ABIERTO
note right on link
  abrirUsuarios()
end note

editarUsuario -[#blue]---> USUARIOS_ABIERTO
note right on link
  cancelar edición
end note
@enduml