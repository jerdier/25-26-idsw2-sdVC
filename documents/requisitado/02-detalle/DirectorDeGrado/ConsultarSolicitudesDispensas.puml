@startuml
title Consultar Solicitud de Dispensa (Perspectiva RUP Final)

skinparam {
    StateBackgroundColor white
    StateBorderColor black
    NoteBackgroundColor lightyellow
    NoteBorderColor black
    ArrowColor green
    linetype ortho
}

DISPENSAS_ABIERTO_INICIAL -[#green]-> consultarSolicitudesDispensas

state "DISPENSAS_ABIERTO" as startState <<sdlreceive>>
state "DISPENSAS_ABIERTO" as endState <<sdlreceive>>

[*] -[#green]-> startState

note left of startState
    Director de Grado <b>solicita</b> seleccionar una solicitud.
    Sistema <b>permite</b> abrir el detalle de la misma.
end note

startState -[#green]-> SOLICITUD_DISPENSA_ABIERTA
note on link
    consultarSolicitudDispensa()
end note

state SOLICITUD_DISPENSA_ABIERTA {
    [*] -[#green]-> VisualizacionYEdicion
    
    state "Visualización y Edición" as VisualizacionYEdicion <<sdlreceive>>
    note right of VisualizacionYEdicion
        Sistema <b>permite</b> visualizar los datos.
        Director de Grado <b>solicita</b> modificar campos mediante
        editarSolicitudDispensa().
    end note
    
    VisualizacionYEdicion -[#green]-> [*]
}

SOLICITUD_DISPENSA_ABIERTA -[#green]down-> endState
note left of endState
    GUARDAR:
    Director de Grado <b>solicita</b> registrar cambios.
    Sistema <b>permite</b> persistir la información.
    
    guardarSolicitudDispensa()
end note

SOLICITUD_DISPENSA_ABIERTA -[#red]down-> endState
note right of endState
    CERRAR:
    Director de Grado <b>solicita</b> salir del detalle.
    Sistema <b>permite</b> descartar cambios.
    
    cerrarSolicitudDispensa()
end note

endState -[#green]-> [*]

@enduml