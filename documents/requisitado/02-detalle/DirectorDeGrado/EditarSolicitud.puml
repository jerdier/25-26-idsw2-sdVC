@startuml
title Editar Solicitud de Dispensa (Perspectiva RUP Final)

skinparam {
    StateBackgroundColor white
    StateBorderColor black
    NoteBackgroundColor lightyellow
    NoteBorderColor black
    ArrowColor green
    linetype ortho
}

state SOLICITUD_DISPENSA_ABIERTA_INICIAL as "SOLICITUD_DISPENSA_ABIERTA"
state DISPENSAS_ABIERTO_FINAL            as "DISPENSAS_ABIERTO"

state "SOLICITUD_DISPENSA_ABIERTA" as startState <<sdlreceive>>
state "SOLICITUD_DISPENSA_ABIERTA" as endState <<sdlreceive>>

[*] -[#green]-> startState

startState -[#green]-> EDITAR_SOLICITUD_DISPENSA
note on link
    editarSolicitudDispensa()
end note

state EDITAR_SOLICITUD_DISPENSA {
    [*] -[#green]-> RevisarSolicitud
    
    state "Revisión de Solicitud" as RevisarSolicitud <<sdlreceive>>
    note left of RevisarSolicitud
        Director de Grado <b>solicita</b> editar solicitud.
        Sistema <b>permite</b> el acceso y <b>muestra</b> datos.
    end note
    
    RevisarSolicitud -[#green]-> ModificarEstadoYDatos
    note on link
        modificarDatosSolicitud()
    end note
    
    state "Modificación de Estado y Datos" as ModificarEstadoYDatos <<sdlreceive>>
    note right of ModificarEstadoYDatos
        Director de Grado <b>solicita</b> modificar:
        • Estado (Aprobar/Rechazar)
        • Observaciones o motivo
        • Otros campos editables
        Sistema <b>permite</b> la edición y
        <b>valida</b> los cambios introducidos.
    end note
    
    ModificarEstadoYDatos -[#green]-> GuardarCambios
    
    state "Guardar Cambios" as GuardarCambios <<sdlreceive>>
    note left of GuardarCambios
        GUARDAR:
        Director de Grado <b>solicita</b> guardar cambios.
        Sistema <b>permite</b> registrar y guardar.
        
        guardarSolicitudDispensa()
    end note
    
    GuardarCambios -[#green]-> [*]
    note on link
        Sistema <b>actualiza</b> el estado y datos,
        <b>registra</b> fecha y responsable, y
        <b>notifica</b> al alumno.
    end note
    
    ModificarEstadoYDatos -[#red]-> [*]
    note on link
        CANCELAR:
        Director de Grado <b>solicita</b> salir.
        Sistema <b>permite</b> descartar cambios.
        
        cerrarSolicitudDispensa()
    end note
}

EDITAR_SOLICITUD_DISPENSA -[#green]-> endState

endState -[#green]-> [*]

@enduml
