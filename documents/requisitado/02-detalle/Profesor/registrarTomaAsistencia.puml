@startuml
skinparam nodesep 60
skinparam ranksep 60
skinparam linetype polyline
skinparam NoteBackgroundColor lightyellow
skinparam NoteBorderColor gray
skinparam StateBackgroundColor #F5F5F5
skinparam StateBorderColor gray

state "registrarTomaAsistencia()" as registrarTomaAsistencia {
    state " " as Paso1
    state " " as Paso2

    [*] -[#green]-> Paso1
    note on link
      <b>Profesor</b> se encuentra en una clase activa
      y solicita pasar lista a los alumnos
    end note

    Paso1 -[#green]-> Paso2
    note on link
      <b>Sistema</b> permite mostrar el listado de alumnos matriculados
    end note

    Paso2 -[#green]-> [*]
    note on link
      <b>Sistema</b> permite introducir el estado de cada alumno
      <b>Profesor</b> introduce los cambios:
      • Presente / Ausente / Tarde
      • Justificación (si aplica)
    end note
}

state "SESION_CLASE_ABIERTA" as SESION_CLASE_ABIERTA

registrarTomaAsistencia -[#blue]---> SESION_CLASE_ABIERTA
note right on link
  cerrarSesiónClase()
end note
@enduml