@startuml
skinparam nodesep 60
skinparam ranksep 60
skinparam linetype polyline
skinparam NoteBackgroundColor lightyellow
skinparam NoteBorderColor gray
skinparam StateBackgroundColor #F5F5F5
skinparam StateBorderColor gray

state "editarSolicitudDispensa()" as editarSolicitudDispensa {

    state " " as Paso1
    state " " as Paso2

    [*] -[#green]-> Paso1
    note on link
      <b>Secretaría</b> solicita editar solicitud de dispensa
    end note

    Paso1 -[#green]-> Paso2
    note on link
      <b>Sistema</b> muestra datos de la solicitud
    end note

    Paso2 -[#green]-> [*]
    note on link
      <b>Secretaría</b> introduce datos actualizados
      <b>Sistema</b> permite editar solicitud
      • Permite solicitar confirmar edición
      • Permite solicitar cancelar edición
    end note
}

state "DISPENSAS_ABIERTO" as DISPENSAS_ABIERTO

editarSolicitudDispensa -[#green]---> DISPENSAS_ABIERTO
note right on link
  abrirDispensas()
end note

editarSolicitudDispensa -[#blue]---> DISPENSAS_ABIERTO
note right on link
  cancelar edición
end note
@enduml
