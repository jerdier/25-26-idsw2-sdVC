@startuml EditarSolicitudDispensa

title Editar solicitud de dispensa

' --- CONFIGURACIÓN DE ESTILO ---

skinparam nodesep 120
skinparam ranksep 120
skinparam linetype ortho
skinparam Padding 10

state SOLICITUD_DISPENSA_ABIERTA_INICIAL as "SOLICITUD_DISPENSA_ABIERTA"
state EDICION_SOLICITUD_COMP             as "EDICION_SOLICITUD_DISPENSA"
state DISPENSAS_ABIERTO_FINAL            as "DISPENSAS_ABIERTO"
state SOLICITUD_DISPENSA_ABIERTA_FINAL   as "SOLICITUD_DISPENSA_ABIERTA"

[*] -[#green]-> SOLICITUD_DISPENSA_ABIERTA_INICIAL

' Entrada al caso de uso
SOLICITUD_DISPENSA_ABIERTA_INICIAL -[#green]-> EDICION_SOLICITUD_COMP : editarSolicitudDispensa()

note left of EDICION_SOLICITUD_COMP
    <b>Alumno solicita</b> editar una
    solicitud de dispensa existente.
    <b>Sistema permite</b> habilitar
    la edición de la información.
end note


state EDICION_SOLICITUD_COMP {

    state PermitirModificacion as "Edición de Datos"
    state ValidarModificaciones as "Validación de Cambios"

    [*] -[#green]-> PermitirModificacion

    note right of PermitirModificacion
        <b>Sistema permite</b> modificar
        los datos de la solicitud.
    end note

    PermitirModificacion -[#green]-> ValidarModificaciones

    note left of ValidarModificaciones
        <b>Alumno solicita</b> registrar
        las modificaciones realizadas.
    end note

    ' Flujo alternativo: error de validación
    ValidarModificaciones -[#red]-> PermitirModificacion

    note right of ValidarModificaciones
        <b>Sistema valida</b> los cambios
        realizados.
        <b>Si hay error:</b>
        informa inconsistencias y
        permite corrección.
    end note

    ' Flujo básico: cambios válidos
    ValidarModificaciones -[#green]-> [*]

    note left of ValidarModificaciones
        <b>Sistema confirma</b> que los
        datos están listos para
        ser guardados.
    end note
}

' --- SALIDAS DEL CASO DE USO ---

EDICION_SOLICITUD_COMP -[#green]---> DISPENSAS_ABIERTO_FINAL : guardarSolicitudDispensa()

note left of DISPENSAS_ABIERTO_FINAL
    <b>GUARDAR:</b>
    <b>Alumno solicita</b> registrar
    los cambios realizados.
    <b>Sistema permite</b> persistir
    la información.
end note


EDICION_SOLICITUD_COMP -[#green]---> SOLICITUD_DISPENSA_ABIERTA_FINAL 

note right of SOLICITUD_DISPENSA_ABIERTA_FINAL
    <b>Alumno solicita</b> mantener
    la solicitud abierta sin
    salir del detalle.
end note


DISPENSAS_ABIERTO_FINAL -[#blue]-> [*]

@enduml
