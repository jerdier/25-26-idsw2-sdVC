@startuml consultarUsuario
skinparam linetype polyline

rectangle #CDEBA5 ":PANEL_ADMINISTRACION" as PanelAdmin
rectangle #CDEBA5 ":DETALLE_USUARIO_MOSTRADO" as DetalleMostrado
rectangle #CDEBA5 ":Collaboration CompletarGestion" as CompletarGestion

package consultarUsuario as "consultarUsuario()" {
    rectangle #629EF9 ConsultarUsuarioView
    rectangle #b5bd68 UsuarioController
    rectangle #F2AC4E UsuarioRepository
}

PanelAdmin --> ConsultarUsuarioView: consultarUsuario()

ConsultarUsuarioView -d-> UsuarioController: buscarUsuario(criterio)
UsuarioController --> UsuarioRepository: obtenerUsuarioPorId(id)

ConsultarUsuarioView ..> DetalleMostrado: <<include>> [éxito]
ConsultarUsuarioView ..> CompletarGestion: <<include>> completarGestion() [cancelación/error]

@enduml