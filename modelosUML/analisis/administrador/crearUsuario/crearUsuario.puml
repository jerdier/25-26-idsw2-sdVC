@startuml crearUsuario
skinparam linetype polyline

rectangle #CDEBA5 ":PANEL_ADMINISTRACION" as PanelAdmin
rectangle #CDEBA5 ":USUARIO_CREADO" as UsuarioCreado
rectangle #CDEBA5 ":Collaboration CompletarGestion" as CompletarGestion

package crearUsuario as "crearUsuario()" {
    rectangle #629EF9 CrearUsuarioView
    rectangle #b5bd68 UsuarioController
    rectangle #F2AC4E UsuarioRepository
}

PanelAdmin --> CrearUsuarioView: crearUsuario()

CrearUsuarioView -d-> UsuarioController: registrarUsuario(datosUsuario)
UsuarioController --> UsuarioRepository: guardarNuevoUsuario(usuario)

CrearUsuarioView ..> UsuarioCreado: <<include>> [éxito]
CrearUsuarioView ..> CompletarGestion: <<include>> completarGestion() [cancelación/error]

@enduml