@startuml editarUsuario-analisis
skinparam linetype polyline

rectangle #CDEBA5 ":DETALLE_USUARIO_MOSTRADO" as DetalleMostrado
rectangle #CDEBA5 ":USUARIO_MODIFICADO" as UsuarioModificado
rectangle #CDEBA5 ":Collaboration CompletarGestion" as CompletarGestion

package editarUsuario as "editarUsuario()" {
    rectangle #629EF9 EditarUsuarioView
    rectangle #b5bd68 UsuarioController
    rectangle #F2AC4E UsuarioRepository
}

DetalleMostrado --> EditarUsuarioView: editarUsuario()

EditarUsuarioView -d-> UsuarioController: modificarUsuario(id, nuevosDatos)
UsuarioController --> UsuarioRepository: actualizarDatosUsuario(usuario)

EditarUsuarioView ..> UsuarioModificado: <<include>> [éxito]
EditarUsuarioView ..> CompletarGestion: <<include>> completarGestion() [cancelación/error]

@enduml