@startuml cerrarSesionClase-analisis
skinparam linetype polyline

rectangle #CDEBA5 ":Sesion Clase Abierta" as SesionClaseAbierta

package cerrarSesionClase as "cerrarSesionClase()" {
    rectangle #629EF9 CerrarSesionClaseView
    rectangle #b5bd68 SesionClaseController
    rectangle #F2AC4E SesionClaseRepository
    rectangle #F2AC4E AsistenciaRepository
    rectangle #F2AC4E SesionDeClase
    rectangle #F2AC4E Asistencia
}

SesionClaseAbierta -r-> CerrarSesionClaseView: cerrarSesionClase()
CerrarSesionClaseView -d-> SesionClaseController: obtenerSesion(sesionId)
SesionClaseController -d-> SesionClaseRepository: obtenerPorId(sesionId)
SesionClaseRepository -d-> SesionDeClase: findById(sesionId)
SesionDeClase --u-> SesionClaseRepository
SesionClaseRepository --u-> SesionClaseController
SesionClaseController -d-> AsistenciaRepository: obtenerPorSesion(sesionId)
AsistenciaRepository -d-> Asistencia: findBySesion(sesionId)
Asistencia --u-> AsistenciaRepository
AsistenciaRepository --u-> SesionClaseController
SesionClaseController -d-> SesionClaseRepository: actualizarEstado(sesionId, CERRADA)
SesionClaseRepository --u-> SesionClaseController
SesionClaseController --u-> CerrarSesionClaseView
@enduml