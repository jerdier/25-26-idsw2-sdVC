@startuml consultarDetalleAlumno-analisis
skinparam linetype polyline

rectangle #CDEBA5 ":Alumnos Abierto" as AlumnosAbierto

package consultarDetalleAlumno as "consultarDetalleAlumno()" {
    rectangle #629EF9 ConsultarDetalleAlumnoView
    rectangle #b5bd68 AlumnoController
    rectangle #F2AC4E AlumnoRepository
    rectangle #F2AC4E AsistenciaRepository
    rectangle #F2AC4E Alumno
    rectangle #F2AC4E Asistencia
}

AlumnosAbierto -r-> ConsultarDetalleAlumnoView: consultarDetalleAlumno()
ConsultarDetalleAlumnoView -d-> AlumnoController: obtenerAlumno(alumnoId)
AlumnoController -d-> AlumnoRepository: obtenerPorId(alumnoId)
AlumnoRepository -d-> Alumno: findById(alumnoId)
Alumno --u-> AlumnoRepository
AlumnoRepository --u-> AlumnoController
AlumnoController -d-> AsistenciaRepository: obtenerPorAlumno(alumnoId)
AsistenciaRepository -d-> Asistencia: findByAlumno(alumnoId)
Asistencia --u-> AsistenciaRepository
AsistenciaRepository --u-> AlumnoController
AlumnoController --u-> ConsultarDetalleAlumnoView
@enduml