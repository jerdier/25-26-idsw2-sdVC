@startuml crearUsuario-analisis
skinparam linetype polyline

rectangle #CDEBA5 ":Usuarios Abierto" as UsuariosAbierto

package crearUsuario as "crearUsuario()" {
    rectangle #629EF9 CrearUsuarioView
    rectangle #b5bd68 UsuarioController
    rectangle #F2AC4E UsuarioRepository
    rectangle #F2AC4E Usuario
}

UsuariosAbierto -r-> CrearUsuarioView: crearUsuario()
CrearUsuarioView -d-> UsuarioController: validarDatos(nombre, email, rol)
UsuarioController -d-> UsuarioRepository: verificarUnicidad(email)
UsuarioRepository --u-> UsuarioController
UsuarioController -d-> UsuarioRepository: crear(nombre, email, password, rol)
UsuarioRepository -d-> Usuario: new(nombre, email, password, rol)
Usuario --u-> UsuarioRepository
UsuarioRepository --u-> UsuarioController
UsuarioController --u-> CrearUsuarioView
@enduml