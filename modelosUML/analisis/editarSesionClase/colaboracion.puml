@startuml editarSesionClase-analisis
skinparam linetype polyline

rectangle #CDEBA5 ":Sesion Clase Abierta" as SesionClaseAbierta

package editarSesionClase as "editarSesionClase()" {
    rectangle #629EF9 EditarSesionClaseView
    rectangle #b5bd68 SesionClaseController
    rectangle #F2AC4E AsignaturaRepository
    rectangle #F2AC4E SesionClaseRepository
    rectangle #F2AC4E Asignatura
    rectangle #F2AC4E SesionDeClase
}

SesionClaseAbierta -r-> EditarSesionClaseView: editarSesionClase()
EditarSesionClaseView -d-> SesionClaseController: obtenerSesion(sesionId)
SesionClaseController -d-> SesionClaseRepository: obtenerPorId(sesionId)
SesionClaseRepository -d-> SesionDeClase: findById(sesionId)
SesionDeClase --u-> SesionClaseRepository
SesionClaseRepository --u-> SesionClaseController
SesionClaseController -d-> AsignaturaRepository: obtenerPorProfesor(profesorId)
AsignaturaRepository -d-> Asignatura: findByProfesor(profesorId)
Asignatura --u-> AsignaturaRepository
AsignaturaRepository --u-> SesionClaseController
SesionClaseController -d-> SesionClaseRepository: actualizar(sesionId, datos)
SesionClaseRepository -d-> SesionDeClase: update(datos)
SesionDeClase --u-> SesionClaseRepository
SesionClaseRepository --u-> SesionClaseController
SesionClaseController --u-> EditarSesionClaseView
@enduml