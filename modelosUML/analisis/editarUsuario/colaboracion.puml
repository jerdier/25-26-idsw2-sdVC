@startuml editarUsuario-analisis
skinparam linetype polyline

rectangle #CDEBA5 ":Usuario Detalle Abierto" as UsuarioDetalleAbierto

package editarUsuario as "editarUsuario()" {
    rectangle #629EF9 EditarUsuarioView
    rectangle #b5bd68 UsuarioController
    rectangle #F2AC4E UsuarioRepository
    rectangle #F2AC4E Usuario
}

UsuarioDetalleAbierto -r-> EditarUsuarioView: editarUsuario()
EditarUsuarioView -d-> UsuarioController: obtenerUsuario(id)
UsuarioController -d-> UsuarioRepository: obtenerPorId(id)
UsuarioRepository -d-> Usuario: findById(id)
Usuario --u-> UsuarioRepository
UsuarioRepository --u-> UsuarioController
UsuarioController -d-> UsuarioRepository: actualizar(id, nombre, email, rol)
UsuarioRepository -d-> Usuario: update(datos)
Usuario --u-> UsuarioRepository
UsuarioRepository --u-> UsuarioController
UsuarioController --u-> EditarUsuarioView
@enduml