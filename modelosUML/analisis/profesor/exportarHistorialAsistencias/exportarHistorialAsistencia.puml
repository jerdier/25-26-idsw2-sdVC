@startuml exportarHistorialAsistencias
skinparam linetype polyline

rectangle #CDEBA5 ":PANEL_PROFESOR" as PanelProfesor
rectangle #CDEBA5 ":DOCUMENTO_ASISTENCIAS_GENERADO" as DocumentoGenerado
rectangle #CDEBA5 ":Collaboration CompletarGestion" as CompletarGestion

package exportarHistorialAsistencias as "exportarHistorialAsistencias()" {
    rectangle #629EF9 ExportarAsistenciasView
    rectangle #b5bd68 ReporteController
    rectangle #F2AC4E AsistenciaRepository
}

PanelProfesor --> ExportarAsistenciasView: exportarHistorialAsistencias()

ExportarAsistenciasView -d-> ReporteController: generarReporteAsistencias(grupoId, formato)
ReporteController --> AsistenciaRepository: extraerMetricasPorGrupo(grupoId)

ExportarAsistenciasView ..> DocumentoGenerado: <<include>> [éxito]
ExportarAsistenciasView ..> CompletarGestion: <<include>> completarGestion() [cancelación/error]

@enduml