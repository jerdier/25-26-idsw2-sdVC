@startuml registrarTomaAsistencia-analisis
skinparam linetype polyline

rectangle #CDEBA5 ":Sesion Clase Abierta" as SesionClaseAbierta

package registrarTomaAsistencia as "registrarTomaAsistencia()" {
    rectangle #629EF9 RegistrarTomaAsistenciaView
    rectangle #b5bd68 AsistenciaController
    rectangle #F2AC4E AlumnoRepository
    rectangle #F2AC4E AsistenciaRepository
    rectangle #F2AC4E Alumno
    rectangle #F2AC4E Asistencia
}

SesionClaseAbierta -r-> RegistrarTomaAsistenciaView: registrarTomaAsistencia(sesionId)
RegistrarTomaAsistenciaView -d-> AsistenciaController: cargarAlumnos(sesionId)
AsistenciaController -d-> AlumnoRepository: obtenerPorSesion(sesionId)
AlumnoRepository -d-> Alumno: findBySesion(sesionId)
Alumno --u-> AlumnoRepository
AlumnoRepository --u-> AsistenciaController
AsistenciaController -d-> AsistenciaRepository: guardarOActualizar(sesionId, alumnoId, presente)
AsistenciaRepository -d-> Asistencia: new(sesionId, alumnoId, presente)
Asistencia --u-> AsistenciaRepository
AsistenciaRepository --u-> AsistenciaController
AsistenciaController --u-> RegistrarTomaAsistenciaView
@enduml