@startuml abrirUsuarios-diseno-secuencia

title Diagrama de Secuencia - Abrir Usuarios (Vue 3 + Express + Prisma)

actor "Administrador" as Admin
participant "Frontend\n(Vue 3)" as Frontend
participant "UsuarioController" as Controller
participant "UsuarioService" as Service
database "Base de Datos\n(PostgreSQL)" as DB

Admin -> Frontend : solicita abrir gestión de usuarios
activate Frontend

Frontend -> Controller : GET /api/admin/usuarios
activate Controller

Controller -> Service : obtenerUsuarios()
activate Service

Service -> DB : SELECT * FROM usuarios
activate DB
DB --> Service : List<Usuario>
deactivate DB

Service --> Controller : List<Usuario>
deactivate Service

Controller --> Frontend : 200 OK { usuarios }
deactivate Controller

Frontend --> Admin : muestra lista de usuarios\n(nombre, apellidos, rol, estado)
deactivate Frontend

@enduml
