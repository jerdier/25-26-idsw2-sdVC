@startuml consultarUsuario
title Diagrama de Secuencia - Consultar Usuario (Diseño)

actor "Administrador" as Admin
participant "Frontend (Vue)" as FE
participant "UsuarioController" as Controller
participant "UsuarioService" as Service
participant "UsuarioRepository" as Repository

Admin -> FE: Solicitar Detalle de Usuario
activate FE

FE -> Controller: GET /api/usuarios/{id}
activate Controller

Controller -> Service: obtenerUsuario(id)
activate Service
Service -> Repository: findById(id)
activate Repository
Repository --> Service: Optional<Usuario>
deactivate Repository

alt Usuario no encontrado
    Service --> Controller: throws NotFoundException
    Controller --> FE: 404 Not Found
else Usuario encontrado
    Service --> Controller: UsuarioDTO
    Controller --> FE: 200 OK
end
deactivate Service

deactivate Controller
deactivate FE
@enduml