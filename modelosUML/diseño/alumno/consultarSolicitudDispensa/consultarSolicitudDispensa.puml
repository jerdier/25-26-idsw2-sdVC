@startuml consultarSolicitudDispensa
title Diagrama de Secuencia - Consultar Solicitud de Dispensa (Diseño)

actor "Alumno" as Student
participant "Frontend (React)" as FE
participant "DispensaController" as Controller
participant "DispensaService" as Service
participant "DispensaRepository" as Repository

Student -> FE: Ver Mis Dispensas
activate FE

FE -> Controller: GET /api/dispensas/alumno/{alumnoId}
activate Controller

Controller -> Service: obtenerDispensasPorAlumno(alumnoId)
activate Service
Service -> Repository: findByAlumnoId(alumnoId)
activate Repository
Repository --> Service: List<Dispensa>
deactivate Repository
Service --> Controller: List<DispensaDTO>
deactivate Service

Controller --> FE: 200 OK
deactivate Controller
deactivate FE
@enduml