@startuml cerrarCicloAcademico-diseno-secuencia

title Diagrama de Secuencia - Cerrar Ciclo Académico (Vue 3 + Express + Prisma)

actor "Secretaria\nAcademica" as Secretaria
participant "Frontend\n(Vue 3)" as Frontend
participant "MatriculaController" as Controller
participant "MatriculaService" as Service
database "Base de Datos\n(PostgreSQL)" as DB

Secretaria -> Frontend : confirma cierre del ciclo académico
activate Frontend

Frontend -> Controller : POST /api/secretaria/ciclos/cerrar
activate Controller

Controller -> Service : cerrarCicloAcademico()
activate Service

Service -> DB : UPDATE Matricula SET estado = 'Historica'\nWHERE estado = 'Vigente'
activate DB
DB --> Service : matriculasActualizadas : Integer
deactivate DB

Service --> Controller : resultado : { matriculasArchivadas }
deactivate Service

Controller --> Frontend : 200 OK { resultado }
deactivate Controller

Frontend --> Secretaria : muestra confirmación de cierre\n(N matrículas archivadas)
deactivate Frontend

@enduml
