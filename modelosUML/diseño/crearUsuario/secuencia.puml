@startuml crearUsuario-diseno-secuencia

title Diagrama de Secuencia - Crear Usuario (Vue 3 + Express + Prisma)

actor "Administrador" as Admin
participant "Frontend\n(Vue 3)" as Frontend
participant "UsuarioController" as Controller
participant "UsuarioService" as Service
database "Base de Datos\n(PostgreSQL)" as DB

Admin -> Frontend : ingresa datos del nuevo usuario\n(nombre, email, password, rol)
activate Frontend

Frontend -> Controller : POST /api/admin/usuarios\n{ nombre, email, password, rol }
activate Controller

Controller -> Service : createUsuario(nombre, email, password, rol)
activate Service

Service -> DB : SELECT * FROM [tabla_rol]\nWHERE email = ?
activate DB
DB --> Service : Optional<Usuario>
deactivate DB

alt no registrado

    Service -> DB : INSERT INTO [tabla_rol]\n(nombre, email, password)\nVALUES (?, ?, ?)
    activate DB
    DB --> Service : usuarioCreado : [Rol]
    deactivate DB

    Service --> Controller : usuarioCreado : [Rol]
    deactivate Service

    Controller --> Frontend : 201 Created\n{ usuarioCreado }
    deactivate Controller

    Frontend --> Admin : usuario creado correctamente
    deactivate Frontend

else ya registrado

    Service --> Controller : throw Error("Email ya registrado")
    Controller --> Frontend : 400 Bad Request\n{ message: "Email ya en uso" }
    Frontend --> Admin : Mostrar error "Email ya en uso"

end

@enduml
