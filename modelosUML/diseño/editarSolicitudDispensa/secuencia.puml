@startuml editarSolicitudDispensa-diseno-secuencia

title Diagrama de Secuencia - Editar Solicitud de Dispensa (Vue 3 + Express + Prisma)

actor "Alumno /\nSecretaria" as AlumnoSecretaria
actor "Director\nde Grado" as Director
participant "Frontend\n(Vue 3)" as Frontend
participant "DispensaController" as Controller
participant "DispensaService" as Service
database "Base de Datos\n(PostgreSQL)" as DB

AlumnoSecretaria -> Frontend : selecciona dispensa a editar
activate Frontend

Frontend -> Controller : GET /api/dispensas/:dispensaId
activate Controller

Controller -> Service : getDispensa(dispensaId)
activate Service

Service -> DB : SELECT * FROM Dispensa\nWHERE id = ?
activate DB
DB --> Service : dispensa : Dispensa
deactivate DB

Service --> Controller : dispensa : Dispensa
deactivate Service

Controller --> Frontend : 200 OK { dispensa }
deactivate Controller

Frontend -> Controller : GET /api/academic/alumno/:alumnoId/sessions
activate Controller

Controller -> Service : getSessionsForAlumno(alumnoId)
activate Service

Service -> DB : SELECT * FROM SesionDeClase\nJOIN Matricula ON ...\nWHERE alumnoId = ?
activate DB
DB --> Service : sesiones : SesionDeClase[]
deactivate DB

Service --> Controller : sesiones : SesionDeClase[]
deactivate Service

Controller --> Frontend : 200 OK { sesiones }
deactivate Controller

Frontend --> AlumnoSecretaria : muestra formulario con datos actuales\ny sesiones disponibles

alt Alumno / Secretaria: modifica contenido

    AlumnoSecretaria -> Frontend : confirma cambios\n(motivo, sesionesIds)

    Frontend -> Controller : PUT /api/dispensas/:id/rectificar\n{ motivo, sesionesIds }
    activate Controller

    Controller -> Service : updateDispensa(id, motivo, sesionesIds)
    activate Service

    Service -> DB : UPDATE Dispensa SET motivo=?\nWHERE id=?
    activate DB
    DB --> Service : dispensaActualizada : Dispensa
    deactivate DB

    Service --> Controller : dispensaActualizada : Dispensa
    deactivate Service

    Controller --> Frontend : 200 OK { dispensaActualizada }
    deactivate Controller

    Frontend --> AlumnoSecretaria : solicitud actualizada correctamente
    deactivate Frontend

else Director de Grado: modifica estado

    Director -> Frontend : confirma resolución\n(estado: APROBADA/RECHAZADA, observaciones)

    Frontend -> Controller : PATCH /api/dispensas/:id/status\n{ estado, observaciones }
    activate Controller

    Controller -> Service : updateStatus(id, estado, observaciones)
    activate Service

    Service -> DB : UPDATE Dispensa\nSET estado=?, observaciones=?\nWHERE id=?
    activate DB
    DB --> Service : dispensaActualizada : Dispensa
    deactivate DB

    Service --> Controller : dispensaActualizada : Dispensa
    deactivate Service

    Controller --> Frontend : 200 OK { dispensaActualizada }
    deactivate Controller

    Frontend --> Director : solicitud resuelta correctamente
    deactivate Frontend

    note over Frontend : Sistema notifica al Alumno\nsobre el nuevo estado

end

@enduml
