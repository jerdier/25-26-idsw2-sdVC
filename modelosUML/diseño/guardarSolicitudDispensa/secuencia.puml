@startuml guardarSolicitudDispensa-diseno-secuencia

title Diagrama de Secuencia - Guardar Solicitud de Dispensa (Vue 3 + Express + Prisma)

actor "Secretaria /\nDirector de Grado" as Actor
participant "Frontend\n(Vue 3)" as Frontend
participant "DispensaController" as Controller
participant "DispensaService" as Service
database "Base de Datos\n(PostgreSQL)" as DB

Actor -> Frontend : solicita guardar dispensa (dispensaId, estado)
activate Frontend

Frontend -> Controller : GET /api/dispensas/:dispensaId
activate Controller

Controller -> Service : getDispensa(dispensaId)
activate Service

Service -> DB : SELECT * FROM Dispensa\nWHERE id = ?
activate DB
DB --> Service : dispensa : Dispensa
deactivate DB

Service --> Controller : dispensa : Dispensa
deactivate Service

Controller --> Frontend : 200 OK { dispensa }
deactivate Controller

Frontend --> Actor : muestra estado actual de la dispensa

Actor -> Frontend : confirma estado final\n(estado: APROBADA / RECHAZADA / PENDIENTE)

Frontend -> Controller : PATCH /api/dispensas/:id/status\n{ estado }
activate Controller

Controller -> Service : updateStatus(id, estado)
activate Service

Service -> DB : UPDATE Dispensa\nSET estado=?\nWHERE id=?
activate DB
DB --> Service : dispensaGuardada : Dispensa
deactivate DB

Service --> Controller : dispensaGuardada : Dispensa
deactivate Service

Controller --> Frontend : 200 OK { dispensaGuardada }
deactivate Controller

Frontend --> Actor : dispensa guardada correctamente
deactivate Frontend

@enduml
