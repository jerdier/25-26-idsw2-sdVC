@startuml cerrarSesionClase
title Diagrama de Secuencia - Cerrar Sesión de Clase (Diseño)

actor "Profesor" as Teacher
participant "Frontend (React)" as FE
participant "SesionController" as Controller
participant "SesionService" as Service
participant "SesionRepository" as Repository

Teacher -> FE: Finalizar Sesión
activate FE

FE -> Controller: PUT /api/sesiones/{id}/cerrar
activate Controller

Controller -> Service: finalizarSesion(id)
activate Service
Service -> Repository: findById(id)
activate Repository
Repository --> Service: Optional<Sesion>
deactivate Repository

Service -> Repository: save(sesionCerrada)
activate Repository
Repository --> Service: Sesion
deactivate Repository
Service --> Controller: void
deactivate Service

Controller --> FE: 200 OK
deactivate Controller
deactivate FE
@enduml