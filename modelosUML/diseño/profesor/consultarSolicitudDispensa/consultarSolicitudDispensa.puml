@startuml consultarSolicitudDispensa
title Diagrama de Secuencia - Consultar Dispensas (Diseño)

actor "Profesor" as Teacher
participant "Frontend (React)" as FE
participant "DispensaController" as Controller
participant "DispensaService" as Service
participant "DispensaRepository" as Repository

Teacher -> FE: Ver Dispensas del Grupo
activate FE

FE -> Controller: GET /api/dispensas/profesor/{profesorId}
activate Controller

Controller -> Service: obtenerDispensasAprobadas(profesorId)
activate Service
Service -> Repository: findAprobadasByProfesor(profesorId)
activate Repository
Repository --> Service: List<Dispensa>
deactivate Repository
Service --> Controller: List<DispensaDTO>
deactivate Service

Controller --> FE: 200 OK
deactivate Controller
deactivate FE
@enduml