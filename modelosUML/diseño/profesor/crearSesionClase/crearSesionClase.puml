@startuml crearSesionClase
title Diagrama de Secuencia - Crear Sesión de Clase (Diseño)

actor "Profesor" as Teacher
participant "Frontend (Vue)" as FE
participant "SesionController" as Controller
participant "SesionService" as Service
participant "SesionRepository" as Repository

Teacher -> FE: Iniciar Nueva Sesión
activate FE

FE -> Controller: POST /api/sesiones
activate Controller

Controller -> Service: aperturarSesion(sesionDTO)
activate Service

alt Hay una sesión activa
    Service --> Controller: throws BusinessException
    Controller --> FE: 409 Conflict
else Creación exitosa
    Service -> Repository: save(nuevaSesion)
    activate Repository
    Repository --> Service: Sesion
    deactivate Repository
    Service --> Controller: SesionDTO
    Controller --> FE: 201 Created
end
deactivate Service

deactivate Controller
deactivate FE
@enduml