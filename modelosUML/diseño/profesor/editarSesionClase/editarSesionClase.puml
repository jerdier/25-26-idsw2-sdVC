@startuml editarSesionClase
title Diagrama de Secuencia - Editar Sesión de Clase (Diseño)

actor "Profesor" as Teacher
participant "Frontend (React)" as FE
participant "SesionController" as Controller
participant "SesionService" as Service
participant "SesionRepository" as Repository

Teacher -> FE: Modificar Sesión
activate FE

FE -> Controller: PUT /api/sesiones/{id}
activate Controller

Controller -> Service: reajustarSesion(id, sesionDTO)
activate Service
Service -> Repository: save(sesionActualizada)
activate Repository
Repository --> Service: Sesion
deactivate Repository
Service --> Controller: SesionDTO
deactivate Service

Controller --> FE: 200 OK
deactivate Controller
deactivate FE
@enduml