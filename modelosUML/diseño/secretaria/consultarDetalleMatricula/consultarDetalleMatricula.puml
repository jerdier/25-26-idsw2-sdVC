@startuml consultarDetalleMatricula
title Diagrama de Secuencia - Consultar Detalle Matrícula (Diseño)

actor "Secretaría" as AdminUser
participant "Frontend (Vue)" as FE
participant "MatriculaController" as Controller
participant "MatriculaService" as Service
participant "MatriculaRepository" as Repository

AdminUser -> FE: Buscar Matrícula
activate FE

FE -> Controller: GET /api/matriculas/{alumnoId}
activate Controller

Controller -> Service: obtenerMatricula(alumnoId)
activate Service
Service -> Repository: findByAlumnoId(alumnoId)
activate Repository
Repository --> Service: Matricula
deactivate Repository
Service --> Controller: MatriculaDTO
deactivate Service

Controller --> FE: 200 OK
deactivate Controller
deactivate FE
@enduml