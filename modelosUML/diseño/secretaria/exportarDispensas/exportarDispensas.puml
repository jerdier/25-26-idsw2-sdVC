@startuml exportarDispensas
title Diagrama de Secuencia - Exportar Dispensas (Diseño)

actor "Secretaría" as AdminUser
participant "Frontend (Vue)" as FE
participant "ReporteController" as Controller
participant "ReporteService" as Service
participant "DispensaRepository" as Repository

AdminUser -> FE: Exportar Registros
activate FE

FE -> Controller: GET /api/reportes/dispensas/exportar
activate Controller

Controller -> Service: estructurarFicheroDispensas(filtros)
activate Service
Service -> Repository: findAll(specification)
activate Repository
Repository --> Service: List<Dispensa>
deactivate Repository
Service --> Controller: byte[] (Archivo Excel)
deactivate Service

Controller --> FE: 200 OK (Content-Disposition: attachment)
deactivate Controller
deactivate FE
@enduml