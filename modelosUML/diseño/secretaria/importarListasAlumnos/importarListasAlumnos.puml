@startuml importarListasAlumnos
title Diagrama de Secuencia - Importar Listas de Alumnos (Diseño)

actor "Secretaría" as AdminUser
participant "Frontend (React)" as FE
participant "ImportacionController" as Controller
participant "ImportacionService" as Service
participant "AlumnoRepository" as Repository

AdminUser -> FE: Subir CSV/Excel Alumnos
activate FE

FE -> Controller: POST /api/alumnos/importar
activate Controller

Controller -> Service: procesarArchivoAlumnos(file)
activate Service

alt Archivo con formato incorrecto
    Service --> Controller: throws FileFormatException
    Controller --> FE: 400 Bad Request
else Procesamiento exitoso
    Service -> Repository: saveAll(loteAlumnos)
    activate Repository
    Repository --> Service: void
    deactivate Repository
    Service --> Controller: ImportResultDTO
    Controller --> FE: 200 OK
end
deactivate Service

deactivate Controller
deactivate FE
@enduml