@startuml importarMatricula
title Diagrama de Secuencia - Importar Matrículas (Diseño)

actor "Secretaría" as AdminUser
participant "Frontend (Vue)" as FE
participant "ImportacionController" as Controller
participant "ImportacionService" as Service
participant "MatriculaRepository" as Repository

AdminUser -> FE: Subir Archivo de Matrículas
activate FE

FE -> Controller: POST /api/matriculas/importar
activate Controller

Controller -> Service: procesarExcelMatriculas(file)
activate Service

alt Datos inconsistentes
    Service --> Controller: throws ValidationException
    Controller --> FE: 400 Bad Request
else Carga masiva exitosa
    Service -> Repository: saveAll(listaMatriculas)
    activate Repository
    Repository --> Service: void
    deactivate Repository
    Service --> Controller: ImportResultDTO
    Controller --> FE: 200 OK
end
deactivate Service

deactivate Controller
deactivate FE
@enduml