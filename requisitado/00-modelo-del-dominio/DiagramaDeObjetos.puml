@startuml

title Diagrama de Objetos - Sistema de Gestión Académica

' --- INSTANCIACIÓN DE OBJETOS ---

object "alumno1:Alumno" as alumno1 {
    nombre = "Pedro Perez"
    codigo = "A001"
}

object "matricula1:Matricula" as matricula1 {
    fecha = "2024-09-01"
    estado = "activa"
}

object "grado1:Grado" as grado1 {
    nombre = "Ingeniería Informática"
    codigo = "GII"
}

object "asignatura1:Asignatura" as asignatura1 {
    nombre = "Lenguajes de Programación"
    codigo = "LP101"
    creditos = 6
}

object "profesor1:Profesor" as profesor1 {
    nombre = "Jose Breñosa"
    departamento = "Informática"
}

object "directorGrado1:DirectorDeGrado" as directorGrado1 {
    nombre = "Manuel Masías"
    departamento = "Informática"
}

object "secretaria1:SecretariaAcademica" as secretaria1 {
    nombre = "Rosa Fernández"
    oficina = "B-201"
}

object "sesion1:SesionDeClase" as sesion1 {
    fecha = "2024-11-15"
    hora = "10:00"
    aula = "A-301"
}

object "asistencia1:Asistencia" as asistencia1 {
    fecha = "2024-11-15"
    presente = true
}

