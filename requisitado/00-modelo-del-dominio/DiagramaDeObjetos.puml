}

' --- RELACIONES EN UN ESCENARIO CONCRETO ---

alumno1 --> matricula1
matricula1 --> grado1
matricula1 --> secretaria1

asignatura1 --> grado1
asignatura1 --> profesor1

' Relación directa corregida: La asignatura contiene matriculado al alumno '
asignatura1 o-- alumno1

asignatura1 *-- sesion1
sesion1 *-- asistencia1
asistencia1 --> profesor1

alumno1 --> dispensa1
dispensa1 --> sesion1
dispensa1 --> directorGrado1
dispensa1 --> secretaria1

grado1 --> directorGrado1
grado1 --> secretaria1
