@startuml ExportarListasAlumnos

title Exportar listado de alumnos

' --- CONFIGURACIÓN DE ESTILO ---

skinparam nodesep 120
skinparam ranksep 120
skinparam linetype ortho
skinparam Padding 10

state LISTAS_ABIERTO_INICIAL   as "LISTAS_ABIERTO"
state EXPORTAR_LISTADO_COMP   as "EXPORTAR_LISTADO_ALUMNOS"
state LISTA_ABIERTA_FINAL     as "LISTA_ABIERTA"
state LISTAS_ABIERTO_FINAL    as "LISTAS_ABIERTO"

[*] -[#green]-> LISTAS_ABIERTO_INICIAL

' Entrada al caso de uso
LISTAS_ABIERTO_INICIAL -[#green]-> EXPORTAR_LISTADO_COMP : exportarListaAlumnos()

note left of EXPORTAR_LISTADO_COMP
    <b>Alumno solicita</b> exportar
    un listado de alumnos por curso.
    <b>Sistema permite</b> definir
    filtros y formato de salida.
end note


state EXPORTAR_LISTADO_COMP {

    state SolicitudFiltros   as "Selección de Filtros"
    state ValidarFiltros     as "Validación de Filtros"
    state SeleccionFormato   as "Selección de Formato"
    state Descarga           as "Descarga de Archivo"

    [*] -[#green]-> SolicitudFiltros

    note right of SolicitudFiltros
        <b>Sistema muestra</b> opciones
        de filtrado por curso
        y asignatura.
    end note

    SolicitudFiltros -[#green]-> ValidarFiltros

    note left of ValidarFiltros
        <b>Alumno solicita</b> aplicar
        los criterios seleccionados.
    end note

    ' Flujo alternativo: error en filtros
    ValidarFiltros -[#red]-> SolicitudFiltros

    note right of ValidarFiltros
        <b>Sistema valida</b> los filtros.
        <b>Si hay error:</b>
        informa inconsistencias y
        solicita corrección.
    end note

    ' Flujo básico: filtros válidos
    ValidarFiltros -[#green]-> SeleccionFormato

    note left of SeleccionFormato
        <b>Sistema solicita</b> el formato
        de salida (PDF, CSV, etc.)
        y el nombre del archivo.
    end note

    SeleccionFormato -[#green]-> Descarga

    note right of Descarga
        <b>Alumno solicita</b> la descarga.
        <b>Sistema permite</b> generar
        el archivo correspondiente.
    end note

    Descarga -[#green]-> [*]

    note left of Descarga
        <b>Sistema confirma</b> la descarga
        del listado generado.
    end note
}

' --- SALIDAS DEL CASO DE USO ---

EXPORTAR_LISTADO_COMP -[#green]---> LISTA_ABIERTA_FINAL : consultarListaAlumnos()

note left of LISTA_ABIERTA_FINAL
    <b>Alumno solicita</b> consultar
    el listado de alumnos exportado.
end note


EXPORTAR_LISTADO_COMP -[#green]---> LISTAS_ABIERTO_FINAL

note right of LISTAS_ABIERTO_FINAL
    <b>Alumno solicita</b> regresar
    al módulo de listas.
end note


LISTAS_ABIERTO_FINAL -[#blue]-> [*]

@enduml
