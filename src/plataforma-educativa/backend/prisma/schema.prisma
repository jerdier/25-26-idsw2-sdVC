generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ACTORES Y ROLES (Identity & Access)
// ==========================================

model SecretariaAcademica {
  id         String      @id @default(uuid())
  nombre     String
  email      String      @unique
  password   String      @default("password123")
  matriculas Matricula[]
  dispensas  Dispensa[]
  grados     Grado[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Profesor {
  id                     String           @id @default(uuid())
  nombre                 String
  email                  String           @unique
  password               String           @default("password123")
  asignaturas            Asignatura[]
  asistenciasRegistradas Asistencia[]
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
}

model DirectorDeGrado {
  id                 String     @id @default(uuid())
  nombre             String
  email              String     @unique
  password           String     @default("password123")
  gradosDirigidos    Grado[]
  dispensasAprobadas Dispensa[]
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}

model Alumno {
  id             String       @id @default(uuid())
  numeroRegistro String       @unique
  nombre         String
  email          String       @unique
  password       String       @default("password123")
  asignaturas    Asignatura[]
  matriculas     Matricula[]
  dispensas      Dispensa[]
  asistencias    Asistencia[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Administrador {
  id        String   @id @default(uuid())
  nombre    String
  email     String   @unique
  password  String   @default("admin123")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// DOMINIO ACADÉMICO (Core Business)
// ==========================================

model Grado {
  id           String               @id @default(uuid())
  nombre       String
  directorId   String?
  director     DirectorDeGrado?     @relation(fields: [directorId], references: [id], onDelete: SetNull)
  secretariaId String?
  secretaria   SecretariaAcademica? @relation(fields: [secretariaId], references: [id], onDelete: SetNull)
  asignaturas  Asignatura[]
  matriculas   Matricula[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model Asignatura {
  id         String          @id @default(uuid())
  nombre     String
  gradoId    String
  grado      Grado           @relation(fields: [gradoId], references: [id], onDelete: Cascade)
  profesorId String?
  profesor   Profesor?       @relation(fields: [profesorId], references: [id], onDelete: SetNull)
  alumnos    Alumno[]
  sesiones   SesionDeClase[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
}

model Matricula {
  id           String              @id @default(uuid())
  fecha        DateTime            @default(now())
  alumnoId     String
  alumno       Alumno              @relation(fields: [alumnoId], references: [id], onDelete: Cascade)
  gradoId      String
  grado        Grado               @relation(fields: [gradoId], references: [id], onDelete: Cascade)
  secretariaId String
  secretaria   SecretariaAcademica @relation(fields: [secretariaId], references: [id], onDelete: Restrict)
}

// ==========================================
// ASISTENCIA Y DISPENSAS (Transaccional)
// ==========================================

model SesionDeClase {
  id           String       @id @default(uuid())
  fecha        DateTime
  aula         String?
  duracion     Int?         @default(60) // en minutos
  estado       EstadoSesion @default(ACTIVA)
  asignaturaId String
  asignatura   Asignatura   @relation(fields: [asignaturaId], references: [id], onDelete: Cascade)
  asistencias  Asistencia[]
  dispensas    Dispensa[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

enum EstadoSesion {
  ACTIVA
  CERRADA
}

model Asistencia {
  id         String        @id @default(uuid())
  presente   Boolean       @default(false)
  fechaHora  DateTime      @default(now())
  sesionId   String
  sesion     SesionDeClase @relation(fields: [sesionId], references: [id], onDelete: Cascade)
  alumnoId   String
  alumno     Alumno        @relation(fields: [alumnoId], references: [id], onDelete: Cascade)
  profesorId String
  profesor   Profesor      @relation(fields: [profesorId], references: [id], onDelete: Restrict)

  @@unique([sesionId, alumnoId])
}

model Dispensa {
  id               String              @id @default(uuid())
  motivo           String
  estado           EstadoDispensa      @default(PENDIENTE)
  fechaSolicitud   DateTime            @default(now())
  alumnoId         String
  alumno           Alumno              @relation(fields: [alumnoId], references: [id], onDelete: Cascade)
  secretariaId     String
  secretaria       SecretariaAcademica @relation(fields: [secretariaId], references: [id], onDelete: Restrict)
  directorId       String?
  director         DirectorDeGrado?    @relation(fields: [directorId], references: [id], onDelete: SetNull)
  sesionesEximidas SesionDeClase[]
  updatedAt        DateTime            @updatedAt
}

enum EstadoDispensa {
  PENDIENTE
  APROBADA
  RECHAZADA
}